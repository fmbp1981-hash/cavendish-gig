{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023"],
    "module": "ESNext",
    "skipLibCheck": true,

    "moduleResolution": "node16",
    "allowJs": true,
    "checkJs": false,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,

    "strict": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": [
    "next.config.mjs",
    "tailwind.config.ts",
    "postcss.config.js",
    "eslint.config.js",
    "tools/**/*.cjs",
    "src/**/*.ts",
    "src/**/*.tsx"
  ]
}
